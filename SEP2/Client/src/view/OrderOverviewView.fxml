                              </Button>
                              <HBox alignment="CENTER" prefHeight="30.0" prefWidth="103.0" spacing="5.0">
                                 <children>
                                    <Button fx:id="decreaseButton" mnemonicParsing="false" onAction="#decreaseButton" text="-">
                                       <font>
                                          <Font size="14.0" />
                                       </font>
                                    </Button>
                                    <Label fx:id="qtyLabel" alignment="CENTER" contentDisplay="CENTER" prefHeight="20.0" prefWidth="21.0" text="0" textAlignment="CENTER">
