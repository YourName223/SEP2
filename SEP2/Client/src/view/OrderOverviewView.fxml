               <children>
                   <Label text="Orders">
                       <font>
                           <Font size="16.0" />
                       </font>
                   </Label>
                  <TableView fx:id="orderTable" minHeight="-Infinity" minWidth="-Infinity" onMouseClicked="#onOrderItemSelected" prefHeight="200.0" prefWidth="360.0">
