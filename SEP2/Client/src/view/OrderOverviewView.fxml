                   <Label prefWidth="360.0" text="Previous Orders">
                       <font>
                           <Font size="16.0" />
                       </font>
                   </Label>
                  <TableView fx:id="orderTable1" maxWidth="-Infinity" minWidth="-Infinity" onMouseClicked="#onOrderItemSelected" prefHeight="400.0" prefWidth="360.0">
                     <columns>
                        <TableColumn fx:id="nameColumn1" prefWidth="454.4000610113144" text="Product" />
                        <TableColumn fx:id="priceColumn1" prefWidth="142.79995727539062" text="Price" />
                        <TableColumn fx:id="qtyColumn1" prefWidth="75.0" text="qty" />
                        <TableColumn fx:id="timeColumn1" prefWidth="75.0" text="time" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#cancelButton" text="🗑">
